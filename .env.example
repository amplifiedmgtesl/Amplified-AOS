NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only — required for /api/users and the notifications module.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Notifications module (lib/notifications) ──
# All optional. With no provider keys set, the module runs against MOCK
# providers (logs, never sends) so the pipeline is fully testable today.
# NEVER prefix these with NEXT_PUBLIC_ — they must stay server-side.

# Email — Resend (AOS uses its own client-owned Resend account)
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=noreply@amplifiedesl.com
NOTIFICATIONS_CC_EMAIL=                 # always-CC for the audit trail (e.g. John)

# SMS — Twilio (requires A2P 10DLC registration before real delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                     # E.164, e.g. +16145551234

# Kill-switch: set to "false" to log-only (write notification_log, send nothing).
# Defaults to enabled; MOCK providers keep it safe with no keys.
NOTIFICATIONS_ENABLED=
